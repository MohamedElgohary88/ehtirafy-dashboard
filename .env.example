VITE_API_BASE_URL=https://ehtraphy.site/Memory-App
VITE_API_VERSION=v1

# Optional temporary token for dashboard calls if auth flow is not wired yet.
# Preferred: save token after login in localStorage under token/auth_token/access_token.
VITE_API_TOKEN=

# Optional endpoint overrides to force exact backend routes for list screens.
VITE_API_CUSTOMERS_ENDPOINT=dashboard/all-clients
VITE_API_FREELANCERS_ENDPOINT=dashboard/all-freelancers
VITE_API_BEST_FREELANCERS_ENDPOINT=best-freelancers
VITE_API_ADVERTISEMENTS_ENDPOINT=dashboard/advertisements
VITE_API_CATEGORIES_ENDPOINT=dashboard/categories
VITE_API_APP_STATS_ENDPOINT=dashboard/statistics
